#
# Clawvisor Proxy + OpenClaw integration (Stage 1, self-hosted).
# Generated at {{ .GeneratedAt }} for bridge {{ .BridgeID }}.
#
# This file is a Compose *override*. It does NOT fully define your
# OpenClaw gateway; it adds the Clawvisor proxy + bootstrap services
# alongside, and adds env + volume mounts to your existing OpenClaw
# service. Run with:
#
#   docker compose -f docker-compose.yml -f clawvisor-proxy.yml up -d
#
# If your OpenClaw service is named something other than
# `openclaw-gateway`, edit that key below to match your compose file.
#
# Regenerate this file from the Clawvisor dashboard any time. Tokens
# embedded here are sensitive — treat this file like an API key.
#

services:
  # --- New services added by the Clawvisor integration -------------------

  clawvisor-proxy:
    image: clawvisor/proxy:latest
    container_name: clawvisor-proxy
    restart: unless-stopped
    networks:
      - clawvisor-net
    ports:
      - "127.0.0.1:8880:8880"    # proxy listener (localhost only)
      - "127.0.0.1:9091:9091"    # proxy admin (for ca.pem + healthz)
    environment:
      CLAWVISOR_SERVER_URL: "{{ .ServerURL }}"
      CLAWVISOR_PROXY_TOKEN: "{{ .ProxyToken }}"
      CLAWVISOR_BRIDGE_ID: "{{ .BridgeID }}"
    volumes:
      - clawvisor-proxy-data:/data
      - clawvisor-shared:/etc/clawvisor
    command:
      - serve
      - --mode=observe
      - --host=0.0.0.0
      - --port=8880
      - --admin-port=9091
      - --data-dir=/data
      # Config comes from CLAWVISOR_* env vars above; no file needed.
      # If you later want to add custom settings via YAML, create
      # /etc/clawvisor/proxy/config.yaml inside the clawvisor-proxy-data
      # volume and add --clawvisor-config=/data/proxy/config.yaml here.

  clawvisor-bootstrap:
    # Runs once at compose-up; writes the proxy config + plugin secrets
    # into the shared volume, then exits. Plugin + proxy read their
    # configs from here on startup.
    image: alpine:3
    container_name: clawvisor-bootstrap
    restart: "no"
    volumes:
      - clawvisor-shared:/etc/clawvisor
    entrypoint:
      - sh
      - -c
      - |
        set -e
        mkdir -p /etc/clawvisor/plugin /etc/clawvisor/proxy
        cat > /etc/clawvisor/plugin/secrets.json <<'PLUGIN_SECRETS_EOF'
        {{ .PluginSecretsJSON }}
        PLUGIN_SECRETS_EOF
        chmod 0600 /etc/clawvisor/plugin/secrets.json
        cat > /etc/clawvisor/proxy/config.yaml <<'PROXY_CONFIG_EOF'
        server_url: "{{ .ServerURL }}"
        proxy_token: "{{ .ProxyToken }}"
        bridge_id: "{{ .BridgeID }}"
        PROXY_CONFIG_EOF
        chmod 0600 /etc/clawvisor/proxy/config.yaml
        echo "Clawvisor plugin + proxy secrets written."

  # --- Override applied to your existing OpenClaw service --------------

  # The service key below must match the name in your primary
  # docker-compose.yml. If your OpenClaw service is called something
  # other than `openclaw-gateway`, rename this key accordingly.
  #
  # Compose merges these fields INTO your existing definition: we add
  # env vars, a volume mount, a dependency, and the Clawvisor network.
  # Image, command, and other fields stay as you had them.
  openclaw-gateway:
    networks:
      - clawvisor-net
    depends_on:
      - clawvisor-proxy
      - clawvisor-bootstrap
    environment:
      HTTP_PROXY:  "http://clawvisor-proxy:8880"
      HTTPS_PROXY: "http://clawvisor-proxy:8880"
      NO_PROXY:    "localhost,127.0.0.1,clawvisor-proxy"
      # Node-specific; covers OpenClaw's tool clients.
      NODE_EXTRA_CA_CERTS: "/etc/clawvisor/ca.pem"
      # OpenSSL / curl fallback.
      SSL_CERT_FILE:       "/etc/clawvisor/ca.pem"
    volumes:
      - clawvisor-shared:/etc/clawvisor:ro

volumes:
  clawvisor-proxy-data:   # proxy-only state: CA keypair, traffic log, signing keys
  clawvisor-shared:       # shared: ca.pem (pub) + plugin secrets + proxy config

networks:
  clawvisor-net:
    driver: bridge

# -------------------------------------------------------------------------
# Optional: egress enforcement (Posture B) — makes proxy bypass
# structurally impossible. Requires iptables on the host; Docker Compose
# doesn't expose an ergonomic hook. See docs/SETUP_PROXY.md for the
# supported paths (host-level iptables rules or K8s NetworkPolicy).
# -------------------------------------------------------------------------
