{{- /*
Shared template blocks used by claude_code.sh.tmpl and codex.sh.tmpl.

Templating fields (installerScriptCtx):
  .AppURL          control-plane / dashboard URL (no trailing slash)
  .LLMURL          LLM-proxy URL (no trailing slash)
  .Claim           single-use claim code minted by the dashboard ("" if absent)
  .UserID          fallback user_id when no claim was minted ("" if absent)
  .AgentName       short name used for the agent (registered with the daemon)
  .AgentSlot       on-disk path slug under ~/.clawvisor/agents and /diffs;
                   equals .AgentName for prod and "<env>/<name>" otherwise
  .Target          harness slug — "claude-code" or "codex"
  .HarnessLabel    display label — "Claude Code" or "Codex"
  .Slug            codex provider-id slug — populated only for the codex template
  .DisplayLabel    codex provider display name — populated only for the codex template
*/ -}}

{{define "preamble"}}#!/bin/sh
# Connect {{.HarnessLabel}} to Clawvisor.
#
# Generated by clawvisor-server. Run as a one-liner:
#
#   curl -fsSL "{{.AppURL}}/skill/install/{{.Target}}.sh?claim=<claim>" | sh
#
# This script is deterministic — no LLM in the loop. It registers a fresh
# agent token with the daemon, persists it, smoke-tests connectivity, writes
# the harness config, and prints a one-line revert pointer.
set -eu

usage() {
    cat >&2 <<'USAGE'
Usage: curl -fsSL "<url>/skill/install/{{.Target}}.sh?..." | sh [-- FLAGS]

Flags:
  --invite-stdin         Read a single-use enrollment invite from stdin and
                         enroll this laptop as the invited member. The invite
                         never appears on the command line, in shell history,
                         or in the process table. Recommended one-liner:
                           printf '%s' "<invite-url>" | \
                             sh -c "$(curl -fsSL <url>/skill/install/{{.Target}}.sh)" -- --invite-stdin
  --invite-file=PATH     Read the invite from PATH instead of stdin (same
                         enrollment; the path, not the invite, is on argv).
  --default-everywhere   Make Clawvisor the default for every session of
                         this harness (writes to its settings file).
  --alias-only           Skip the settings file and install a shell alias
                         (`codex-cv` / `claude-cv` by default) instead.
  --alias-name=NAME      Name to use for the alias function (alias mode
                         only; default `codex-cv` / `claude-cv`).
  --yolo                 In alias mode, pass the harness's "skip prompts"
                         flag (--dangerously-bypass-approvals-and-sandbox
                         for codex; --dangerously-skip-permissions for
                         claude).
  --no-yolo              Don't pass that flag.
  --no-tui               Use the plain [y/n] prompts instead of the
                         arrow-key selector (also: CLAWVISOR_NO_TUI=1).
  -h, --help             Show this help and exit.

Without --default-everywhere / --alias-only, the script reads /dev/tty.
USAGE
    exit 2
}

CV_DEFAULT_MODE=""    # "yes" (default-everywhere) or "no" (alias-only)
CV_YOLO=""            # "yes" or "no"
CV_ALIAS_NAME=""      # function name for alias mode (default in per-target tmpl)
CV_NO_TUI="${CLAWVISOR_NO_TUI:-0}"  # 1 disables the arrow-key selector
CV_INVITE_STDIN=""    # "1" when --invite-stdin was passed
CV_INVITE_FILE=""     # path when --invite-file=PATH was passed
for arg in "$@"; do
    case "$arg" in
        --invite-stdin)       CV_INVITE_STDIN=1 ;;
        --invite-file=*)      CV_INVITE_FILE=${arg#--invite-file=} ;;
        --default-everywhere) CV_DEFAULT_MODE=yes ;;
        --alias-only)         CV_DEFAULT_MODE=no  ;;
        --alias-name=*)       CV_ALIAS_NAME=${arg#--alias-name=} ;;
        --yolo)               CV_YOLO=yes ;;
        --no-yolo)            CV_YOLO=no  ;;
        --no-tui)             CV_NO_TUI=1 ;;
        -h|--help)            usage ;;
        *) echo "unknown flag: $arg" >&2; usage ;;
    esac
done

need() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "missing required tool: $1" >&2
        exit 1
    }
}
need curl
need jq

# prompt_yn <message> <default-yes|default-no>
# Reads /dev/tty so it works inside `curl ... | sh`. If /dev/tty is not
# available (rare; some CI), returns the supplied default and prints a hint
# about the matching --flag.
prompt_yn() {
    msg=$1
    default=$2
    if [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
        echo "$msg (no tty; defaulting to $default — pass --default-everywhere/--alias-only/--yolo/--no-yolo to override)" >&2
        case "$default" in yes) return 0 ;; *) return 1 ;; esac
    fi
    while :; do
        printf '%s [y/n] ' "$msg" >/dev/tty
        IFS= read -r answer </dev/tty || answer=""
        case "$answer" in
            [Yy]|[Yy][Ee][Ss]) return 0 ;;
            [Nn]|[Nn][Oo])     return 1 ;;
            "")
                case "$default" in yes) return 0 ;; *) return 1 ;; esac
                ;;
            *) printf 'please answer y or n.\n' >/dev/tty ;;
        esac
    done
}

# prompt_choice <question> <label0> <label1>
# Renders a two-option arrow-key selector reading /dev/tty in raw mode.
# Returns 0 if label0 is picked, 1 if label1 is picked. label0 is the
# initial highlight (the recommended / safer choice).
#
# Falls back to prompt_yn when:
#   - /dev/tty isn't readable/writable (curl|sh in CI, etc.)
#   - $TERM is unset or "dumb" (terminal can't handle ANSI cursor moves)
#   - --no-tui / CLAWVISOR_NO_TUI=1 was passed
# In fallback mode, prompt_yn's "yes" maps to label1 (the second option),
# matching how the callers map "yes" to default-everywhere / yolo.
prompt_choice() {
    msg=$1
    label0=$2
    label1=$3

    if [ ! -r /dev/tty ] || [ ! -w /dev/tty ] \
        || [ "${TERM:-dumb}" = dumb ] \
        || [ "${CV_NO_TUI:-0}" = 1 ]; then
        # Phrase the fallback yn so "yes" = label1 (the second option).
        if prompt_yn "$msg" no; then
            return 1
        fi
        return 0
    fi

    # Save tty state and install cleanup so a Ctrl-C / crash doesn't leave
    # the terminal in raw mode without an echoed cursor.
    _prompt_old_stty=$(stty -g </dev/tty 2>/dev/null) || _prompt_old_stty=""
    _prompt_cleanup() {
        [ -n "$_prompt_old_stty" ] && stty "$_prompt_old_stty" </dev/tty 2>/dev/null
        printf '\033[?25h' >/dev/tty 2>/dev/null
    }
    trap '_prompt_cleanup; exit 130' INT TERM
    trap '_prompt_cleanup' EXIT
    stty -icanon -echo </dev/tty 2>/dev/null
    printf '\033[?25l' >/dev/tty   # hide cursor

    selected=0

    # Initial draw: question (1 line) + two options (2 lines). Cursor ends
    # up 3 lines below where the question started — every redraw / collapse
    # moves up by exactly that count.
    _prompt_render_options() {
        if [ "$selected" = 0 ]; then
            printf '  \033[36m\xe2\x9d\xaf\033[0m %s\n' "$label0" >/dev/tty
            printf '    \033[2m%s\033[0m\n' "$label1" >/dev/tty
        else
            printf '    \033[2m%s\033[0m\n' "$label0" >/dev/tty
            printf '  \033[36m\xe2\x9d\xaf\033[0m %s\n' "$label1" >/dev/tty
        fi
    }
    printf '\033[36m?\033[0m \033[1m%s\033[0m\n' "$msg" >/dev/tty
    _prompt_render_options

    _prompt_redraw_options() {
        # Cursor is below the two options; move back up to the first option
        # line, clear to end of screen, re-render. Net cursor displacement
        # is zero.
        printf '\033[2A\033[J' >/dev/tty
        _prompt_render_options
    }

    # Read one byte at a time via dd. Escape sequences for arrow keys arrive
    # as ESC [ A (up) / ESC [ B (down); other keys arrive as a single byte.
    while :; do
        ch=$(dd if=/dev/tty bs=1 count=1 2>/dev/null) || break
        # Enter (\r or \n) → command substitution stripped the trailing
        # newline, so ch is empty when the user hits return.
        if [ -z "$ch" ]; then
            break
        fi
        case "$ch" in
            "$(printf '\033')")
                # Possible CSI; read the next two bytes for [X.
                _br=$(dd if=/dev/tty bs=1 count=1 2>/dev/null)
                if [ "$_br" = '[' ]; then
                    _key=$(dd if=/dev/tty bs=1 count=1 2>/dev/null)
                    case "$_key" in
                        A) selected=0 ;;       # arrow up
                        B) selected=1 ;;       # arrow down
                    esac
                    _prompt_redraw_options
                fi
                ;;
            k|K) selected=0; _prompt_redraw_options ;;  # vim-style
            j|J) selected=1; _prompt_redraw_options ;;
            q|Q)
                _prompt_cleanup
                trap - INT TERM EXIT
                echo "cancelled" >&2
                exit 130
                ;;
        esac
    done

    _prompt_cleanup
    trap - INT TERM EXIT

    # Collapse the 3-line selector frame (question + 2 options) into a
    # single confirmation line that overwrites where the question was.
    # Cursor is below the options after the loop, so up 3 lands on the
    # question row; clear-to-end-of-screen wipes question + options.
    printf '\033[3A\033[J' >/dev/tty
    if [ "$selected" = 0 ]; then
        printf '\033[36m?\033[0m \033[1m%s\033[0m \033[2m· %s\033[0m\n' "$msg" "$label0" >/dev/tty
    else
        printf '\033[36m?\033[0m \033[1m%s\033[0m \033[2m· %s\033[0m\n' "$msg" "$label1" >/dev/tty
    fi
    return "$selected"
}

# prompt_text <question> <default> [<validation-regex>]
# Reads /dev/tty for a free-text response with a printed default. Writes
# the chosen value to stdout. Empty input or no-tty / --no-tui falls back
# to the default with no prompt. Loops until input matches the regex
# (defaults to safe shell identifier: letters, digits, _, -).
prompt_text() {
    msg=$1
    default=$2
    regex=${3:-'^[A-Za-z_][A-Za-z0-9_-]*$'}

    if [ ! -r /dev/tty ] || [ ! -w /dev/tty ] || [ "${CV_NO_TUI:-0}" = 1 ]; then
        printf '%s\n' "$default"
        return 0
    fi
    while :; do
        printf '\033[36m?\033[0m \033[1m%s\033[0m \033[2m(%s)\033[0m: ' "$msg" "$default" >/dev/tty
        IFS= read -r answer </dev/tty || answer=""
        [ -z "$answer" ] && answer="$default"
        if printf '%s' "$answer" | grep -Eq "$regex"; then
            printf '%s\n' "$answer"
            return 0
        fi
        printf '  \033[33minvalid — use letters, digits, _ or -\033[0m\n' >/dev/tty
    done
}

AGENT_NAME='{{.AgentName}}'
AGENT_SLOT='{{.AgentSlot}}'
HARNESS='{{.Target}}'
HARNESS_LABEL='{{.HarnessLabel}}'
APP_URL='{{.AppURL}}'
LLM_URL='{{.LLMURL}}'
HOST_OS=$(uname -s)

# --- Read the enrollment invite (never off argv/env-on-the-command-line) -----
# The invite is a single-use bearer credential. It is read ONLY from stdin or a
# file so it never lands in shell history or the process table (`ps` lists
# argv, not this). CLAWVISOR_INVITE is accepted as a documented, argv/env-
# exposed fallback for non-interactive CI (spec 04 invite security rule 3).
CV_INVITE=""
if [ -n "$CV_INVITE_FILE" ]; then
    [ -r "$CV_INVITE_FILE" ] || { echo "cannot read --invite-file: $CV_INVITE_FILE" >&2; exit 1; }
    CV_INVITE=$(cat "$CV_INVITE_FILE")
elif [ -n "$CV_INVITE_STDIN" ]; then
    # Read one line from stdin. In the recommended one-liner the invite is piped
    # in on fd 0 while the script body is delivered as an argument to sh
    # (sh -c "$(curl ...)" -- --invite-stdin), leaving fd 0 free for the secret.
    IFS= read -r CV_INVITE || true
elif [ -n "${CLAWVISOR_INVITE:-}" ]; then
    CV_INVITE=$CLAWVISOR_INVITE
fi
# Normalize: accept a raw cvinv_ token OR a full invite URL
# (https://<fqdn>/join?token=cvinv_...). Extraction is pure shell parameter
# expansion — no external command ever receives the secret on its argv. printf
# is a POSIX special builtin, so the pipe into tr does not fork the value out.
case "$CV_INVITE" in
    *token=*)
        CV_INVITE=${CV_INVITE#*token=}
        CV_INVITE=${CV_INVITE%%&*}
        ;;
esac
CV_INVITE=$(printf '%s' "$CV_INVITE" | tr -d '\r\n')
if [ -n "$CV_INVITE_STDIN$CV_INVITE_FILE" ] && [ -z "$CV_INVITE" ]; then
    echo "no invite value found — nothing to enroll with" >&2
    echo "pipe the invite in, e.g.:" >&2
    echo "  printf '%s' \"<invite-url>\" | sh -c \"\$(curl -fsSL $APP_URL/skill/install/$HARNESS.sh)\" -- --invite-stdin" >&2
    exit 1
fi
# Shape guard. If --invite-stdin was used with the naive "curl … | sh" form,
# sh's stdin is the script itself, so `read` grabs a line of shell source
# instead of the invite — catch that here with a clear pointer at the form that
# actually frees fd 0 for the secret (script delivered as an argument to sh).
if [ -n "$CV_INVITE" ]; then
    case "$CV_INVITE" in
        cvinv_*) : ;;
        *)
            echo "that doesn't look like a Clawvisor invite (expected a cvinv_… token or invite URL)." >&2
            echo "If you ran 'curl … | sh -s -- --invite-stdin', the invite can't ride that pipe —" >&2
            echo "sh is already reading the script on stdin. Use this form instead:" >&2
            echo "  printf '%s' \"<invite-url>\" | sh -c \"\$(curl -fsSL $APP_URL/skill/install/$HARNESS.sh)\" -- --invite-stdin" >&2
            exit 1
            ;;
    esac
fi
{{end -}}

{{- /*
mint emits the connect-with-claim curl + token extraction. The claim auto-
approves on the daemon side (the dashboard minted it for this user), so the
curl returns the token immediately without a wait=true long-poll.
*/ -}}

{{define "mint"}}# --- Mint an agent connection -------------------------------------------------
echo "→ Registering {{.HarnessLabel}} agent with Clawvisor at $APP_URL"

# Idempotent re-run: if this agent name already has a token file locally
# and the token is still accepted by the daemon, reuse it instead of
# minting fresh. Makes the install re-pasteable after a stall — e.g. when
# the user timed out waiting for a key vault and pastes the same URL
# again (which still has the now-consumed claim code in it).
EXISTING_JSON="$HOME/.clawvisor/agents/$AGENT_SLOT.json"
TOKEN=""
AGENT_ID=""
if [ -f "$EXISTING_JSON" ]; then
    EXISTING_TOKEN=$(jq -r '.token // empty' "$EXISTING_JSON" 2>/dev/null)
    if [ -n "$EXISTING_TOKEN" ] && curl -sf \
            -H "X-Clawvisor-Agent-Token: $EXISTING_TOKEN" \
            "$APP_URL/api/skill/catalog" -o /dev/null 2>/dev/null; then
        TOKEN="$EXISTING_TOKEN"
        AGENT_ID=$(jq -r '.agent_id // empty' "$EXISTING_JSON" 2>/dev/null)
        echo "✓ Reusing existing agent token from $EXISTING_JSON"
    fi
fi

if [ -z "$TOKEN" ]; then
    if [ -n "$CV_INVITE" ]; then
        # --- Enroll via single-use invite (spec 04 / AGENT-GUIDE §2A) --------
        # The invite claims a member account (email possession proven by holding
        # the invite URL, magic-link mode), registers this per-user agent, and
        # returns its cvis_ token — all in one call to /api/agents/enroll.
        #
        # The invite is fed to jq on stdin (printf is a POSIX builtin, so the
        # token never reaches an external process's argv) and the resulting body
        # is handed to curl on stdin via --data @-. At no point is the invite on
        # a command line, in shell history, or in the process table.
        echo "→ Claiming invite and registering {{.HarnessLabel}} agent at $APP_URL"
        ENROLL_BODY=$(printf '%s' "$CV_INVITE" | jq -Rs \
            --arg name "$AGENT_NAME" \
            --arg desc "$HARNESS_LABEL on $HOST_OS" \
            --arg harness "$HARNESS" \
            --arg host_os "$HOST_OS" \
            '{invite_token: rtrimstr("\n"), name:$name, description:$desc, install_context:{harness:$harness, host_os:$host_os, mode:"sh-invite"}}')
        RESPONSE=$(printf '%s' "$ENROLL_BODY" | curl -sS -X POST "$APP_URL/api/agents/enroll" \
            -H 'Content-Type: application/json' \
            --data @-) || {
            echo "could not reach Clawvisor at $APP_URL" >&2
            exit 1
        }
        TOKEN=$(printf '%s' "$RESPONSE" | jq -r '.token // empty')
        if [ -z "$TOKEN" ]; then
            STATUS=$(printf '%s' "$RESPONSE" | jq -r '.code // .error // "unknown"')
            echo "invite enrollment failed ($STATUS)" >&2
            exit 1
        fi
        AGENT_ID=$(printf '%s' "$RESPONSE" | jq -r '.agent_id // empty')
        echo "✓ Invite claimed — agent registered"
    else
{{if .Claim -}}
        CONNECT_URL="$APP_URL/api/agents/connect?claim={{.Claim}}"
{{- else if .UserID -}}
        CONNECT_URL="$APP_URL/api/agents/connect?user_id={{.UserID}}&wait=true&timeout=120"
{{- else -}}
        CONNECT_URL="$APP_URL/api/agents/connect?wait=true&timeout=120"
{{- end}}

        CONNECT_BODY=$(jq -nc \
            --arg name "$AGENT_NAME" \
            --arg desc "$HARNESS_LABEL on $HOST_OS" \
            --arg harness "$HARNESS" \
            --arg host_os "$HOST_OS" \
            '{name:$name, description:$desc, install_context:{harness:$harness, host_os:$host_os, mode:"sh-one-liner"}}')

        # The claim has 120s of validity from when the dashboard minted it; if
        # it's already expired or consumed (re-paste after a timeout), the
        # daemon returns 401 INVALID_CLAIM here. The idempotent-reuse branch
        # above handles the most common re-paste case — this fallback fires
        # only when there's no local token file at all.
        RESPONSE=$(curl -sS -X POST "$CONNECT_URL" \
            -H 'Content-Type: application/json' \
            --data "$CONNECT_BODY") || {
            echo "could not reach Clawvisor at $APP_URL" >&2
            exit 1
        }
        TOKEN=$(printf '%s' "$RESPONSE" | jq -r '.token // empty')
        if [ -z "$TOKEN" ]; then
            STATUS=$(printf '%s' "$RESPONSE" | jq -r '.status // .error // "unknown"')
            echo "agent registration failed (status: $STATUS): $RESPONSE" >&2
            exit 1
        fi
        # AGENT_ID is captured so per-target steps can scope dashboard URLs and
        # credential lookups to this specific agent — see the credential
        # pre-flight in claude_code.sh.tmpl.
        AGENT_ID=$(printf '%s' "$RESPONSE" | jq -r '.agent_id // empty')
        echo "✓ Agent registered"
    fi
fi
{{end -}}

{{define "persist_token"}}# --- Persist the token --------------------------------------------------------
AGENT_JSON="$HOME/.clawvisor/agents/$AGENT_SLOT.json"
mkdir -p "$(dirname "$AGENT_JSON")"
jq -n \
    --arg name "$AGENT_NAME" \
    --arg agent_id "$AGENT_ID" \
    --arg harness "$HARNESS" \
    --arg installed_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg token "$TOKEN" \
    '{name:$name, agent_id:$agent_id, harness:$harness, installed_at:$installed_at, token:$token}' \
    > "$AGENT_JSON"
chmod 600 "$AGENT_JSON"
echo "✓ Token saved to $AGENT_JSON (chmod 600)"
{{end -}}

{{define "smoke_test"}}# --- Smoke test: token is live -----------------------------------------------
if ! curl -sf -H "X-Clawvisor-Agent-Token: $TOKEN" \
        "$APP_URL/api/skill/catalog" -o /dev/null; then
    echo "smoke test failed: daemon rejected the new token at $APP_URL/api/skill/catalog" >&2
    echo "(was the daemon restarted between mint and verify?)" >&2
    exit 1
fi
echo "✓ Token accepted by daemon"
{{end -}}
