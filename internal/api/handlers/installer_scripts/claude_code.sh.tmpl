{{- template "preamble" . -}}
{{- template "mint" . -}}
{{- template "persist_token" . -}}

# --- Ensure an upstream Anthropic key is vaulted in Clawvisor ---------------
# Claude Code's calls flow through Clawvisor's proxy, which substitutes an
# upstream Anthropic key on each call. If one isn't vaulted yet, point the
# user at the agent-scoped dashboard page and poll the credentials endpoint
# until the key shows up — same shape as the old LLM-driven installer's
# sectionEnsureVaultedKeyDynamic, but without an LLM in the loop.
#
# Accept either user-scope (stored==true) or agent-scope (agent_stored==true);
# any prior install on this user's account is fine. curl/jq failure is
# treated as "absent" so a network blip just defers detection to the next
# 2s tick (idempotent retry).
have_anthropic_key() {
    curl -sS -H "Authorization: Bearer $TOKEN" \
        "$APP_URL/api/runtime/llm-credentials?agent_id=$AGENT_ID" 2>/dev/null \
        | jq -e '.credentials[]? | select(.provider=="anthropic" and (.stored==true or .agent_stored==true))' \
        >/dev/null 2>&1
}

if ! have_anthropic_key; then
    cat <<EOF

  Clawvisor doesn't have an Anthropic API key vaulted yet — its proxy
  needs one to forward Claude Code's calls. Open this page to add one:

    $APP_URL/dashboard/keys/anthropic?for=$AGENT_ID

  Waiting (up to ~3 minutes; Ctrl-C to abort)…
EOF
    printf '  '
    waited=0
    while [ "$waited" -lt 180 ]; do
        if have_anthropic_key; then
            printf '\n'
            echo "✓ Anthropic key vaulted"
            break
        fi
        sleep 2
        waited=$((waited + 2))
        printf '.'
    done
    if ! have_anthropic_key; then
        printf '\n'
        echo "Timed out waiting for the Anthropic key. Re-run this install when ready." >&2
        exit 1
    fi
fi

# --- End-to-end smoke test: make claude actually round-trip through Clawvisor.
# Pre-flight above already confirmed a key is vaulted, so a failure here
# almost always means the vaulted key itself is invalid (revoked, wrong
# account) or the daemon can't reach Anthropic from this host. Inline env
# wins over settings.json, so this works whether or not the user already
# has an ~/.claude/settings.json. Skips gracefully when `claude` isn't on
# $PATH (e.g. seeding a token for another machine).
if command -v claude >/dev/null 2>&1; then
    echo "→ Smoke-testing claude through Clawvisor…"
    # </dev/null is load-bearing: when this script is running via
    # `curl | sh`, sh's stdin IS the curl pipe carrying the rest of
    # the script. `claude -p` reads stdin (for the piped-prompt
    # pattern), so without this redirect claude consumes the rest of
    # the script and sh exits silently at EOF after claude returns.
    SMOKE_OUT=$(
        CLAWVISOR_URL="$APP_URL" \
        CLAWVISOR_AGENT_TOKEN="$TOKEN" \
        ANTHROPIC_BASE_URL="$LLM_URL/api" \
        ANTHROPIC_CUSTOM_HEADERS="X-Clawvisor-Agent-Token: $TOKEN" \
        ANTHROPIC_AUTH_TOKEN= \
        ANTHROPIC_API_KEY= \
        claude -p "respond with the word OK" </dev/null 2>&1
    ) || {
        cat >&2 <<EOF
claude end-to-end smoke test failed. A key is vaulted but the round-trip
failed — the most likely cause is the vaulted key was rejected by
Anthropic (revoked, wrong account, exhausted quota). Re-vault here:

  $APP_URL/dashboard/keys/anthropic?for=$AGENT_ID

Raw error from claude:
EOF
        printf '%s\n' "$SMOKE_OUT" >&2
        exit 1
    }
    echo "✓ Claude round-tripped through Clawvisor"
else
    echo "(skipping end-to-end test — 'claude' CLI not on \$PATH)"
fi

# --- Ask: make Clawvisor the default for every Claude Code session? ---------
# Default-everywhere writes env keys + curl auto-approve rules to
# ~/.claude/settings.json, which Claude Code reads on every session in any
# directory. Alias-only leaves settings.json untouched and instead installs
# a `claude-cv` shell function that sets the env vars for just that
# invocation — useful when the user wants to opt in per-call rather than
# globally.
if [ -z "$CV_DEFAULT_MODE" ]; then
    if prompt_choice \
        "How should Clawvisor route your Claude Code calls?" \
        "Make it the default for every claude session (~/.claude/settings.json)" \
        "Install a 'claude-cv' shell alias (opt in per session)"
    then
        CV_DEFAULT_MODE=yes
    else
        CV_DEFAULT_MODE=no
    fi
fi

# Pick the shell rc file once — only the alias branch writes to it, but the
# resolution lives here so both branches print a consistent message.
case "$SHELL" in
    */zsh)  RC="$HOME/.zshrc" ;;
    */bash) RC="$HOME/.bashrc" ;;
    */fish) RC="$HOME/.config/fish/config.fish" ;;
    *)      RC="" ;;
esac

if [ "$CV_DEFAULT_MODE" = yes ]; then
    # --- Default-everywhere: merge ~/.claude/settings.json ------------------
    # Claude Code reads env from settings.json. Merge the Clawvisor env keys
    # alongside whatever the user already has. Existing unrelated env
    # entries are preserved.
    SETTINGS="$HOME/.claude/settings.json"
    mkdir -p "$HOME/.claude"
    [ -f "$SETTINGS" ] || echo '{}' > "$SETTINGS"

    ANTHROPIC_BASE="$LLM_URL/api"
    CUSTOM_HEADERS="X-Clawvisor-Agent-Token: $TOKEN"

    # Preserve the file's existing keys, then layer env + permission allow
    # rules on top. The allow list is deduplicated by exact-string match so
    # re-running the installer is idempotent.
    jq \
        --arg url "$APP_URL" \
        --arg token "$TOKEN" \
        --arg base "$ANTHROPIC_BASE" \
        --arg headers "$CUSTOM_HEADERS" \
        --arg rule_url '{{.RelayPermissionRule}}' \
        '
        .env = ((.env // {}) + {
            CLAWVISOR_URL: $url,
            CLAWVISOR_AGENT_TOKEN: $token,
            ANTHROPIC_BASE_URL: $base,
            ANTHROPIC_CUSTOM_HEADERS: $headers,
            ANTHROPIC_AUTH_TOKEN: "",
            ANTHROPIC_API_KEY: ""
        })
        | .permissions = ((.permissions // {}))
        | .permissions.allow = (
            ((.permissions.allow // []) + [
                "Bash(curl *http://localhost:25297/*)",
                "Bash(curl *$CLAWVISOR_URL/*)",
                $rule_url
            ]) | unique
        )
        ' "$SETTINGS" > "$SETTINGS.tmp" && mv "$SETTINGS.tmp" "$SETTINGS"
    echo "✓ Updated $SETTINGS"
    INSTALL_MODE_LABEL=default-everywhere
else
    # --- Alias-only: install a claude-cv() shell function -------------------
    # Leaves bare `claude` untouched. The user opts in by typing `claude-cv`
    # instead. The function sets the env vars per-invocation and (optionally)
    # passes --dangerously-skip-permissions so the user isn't double-prompted
    # by Claude Code for each Clawvisor-bound curl.
    if [ -z "$CV_YOLO" ]; then
        if prompt_choice \
            "How should 'claude-cv' handle Claude Code's permission prompts?" \
            "Skip them (--dangerously-skip-permissions)" \
            "Keep them on (Claude asks before each curl)"
        then
            CV_YOLO=yes
        else
            CV_YOLO=no
        fi
    fi

    if [ "$CV_YOLO" = yes ]; then
        SKIP_FLAG=" --dangerously-skip-permissions"
    else
        SKIP_FLAG=""
    fi

    mkdir -p "$HOME/.clawvisor/diffs/$AGENT_NAME"

    if [ -n "$RC" ]; then
        # The function body inlines the env-var setup and the optional skip
        # flag. Idempotent on re-runs by exact-substring match against the
        # agent-token lookup path — flipping yolo/no-yolo on a re-install
        # requires deleting the existing block manually (the diff record
        # under ~/.clawvisor/diffs/$AGENT_NAME/ shows exactly what to strip).
        FUNC_BLOCK=$(cat <<EOF
claude-cv() {
    CLAWVISOR_URL="$APP_URL" \\
    CLAWVISOR_AGENT_TOKEN="\$(jq -r .token \$HOME/.clawvisor/agents/$AGENT_NAME.json)" \\
    ANTHROPIC_BASE_URL="$LLM_URL/api" \\
    ANTHROPIC_CUSTOM_HEADERS="X-Clawvisor-Agent-Token: \$CLAWVISOR_AGENT_TOKEN" \\
    ANTHROPIC_AUTH_TOKEN= \\
    ANTHROPIC_API_KEY= \\
        claude$SKIP_FLAG "\$@"
}
EOF
)
        if ! grep -F -q "agents/$AGENT_NAME.json" "$RC" 2>/dev/null; then
            printf '\n%s\n' "$FUNC_BLOCK" >> "$RC"
            jq -n \
                --arg file "$RC" \
                --arg content "$FUNC_BLOCK" \
                '{file:$file, type:"text_append", content:$content}' \
                > "$HOME/.clawvisor/diffs/$AGENT_NAME/claude_cv.json"
            echo "✓ Appended claude-cv() to $RC"
        else
            echo "  (claude-cv() already references this agent; leaving $RC untouched)"
        fi
    else
        echo "  (unknown shell: $SHELL — append the claude-cv function manually)" >&2
    fi
    INSTALL_MODE_LABEL=alias-only
fi

# --- Write the uninstall reference -------------------------------------------
# Mode-aware: tells the user which files were actually touched.
UNINSTALL_DOC="$HOME/.clawvisor/uninstall-claude-code.md"
if [ "$INSTALL_MODE_LABEL" = default-everywhere ]; then
    cat > "$UNINSTALL_DOC" <<EOF
# How to disconnect Claude Code from Clawvisor (default-everywhere install)

1. Edit ~/.claude/settings.json and remove these keys from the top-level
   \`env\` object (leave any unrelated env keys in place):
       CLAWVISOR_URL, CLAWVISOR_AGENT_TOKEN,
       ANTHROPIC_BASE_URL, ANTHROPIC_CUSTOM_HEADERS,
       ANTHROPIC_AUTH_TOKEN, ANTHROPIC_API_KEY
   Also remove any \`Bash(curl *…clawvisor…/*)\` entries from
   \`.permissions.allow\`.
2. Delete the token file: rm ~/.clawvisor/agents/$AGENT_NAME.json
3. Revoke the agent in the Clawvisor dashboard under Agents → $AGENT_NAME → Delete.
4. Restart Claude Code so the cleared env takes effect.
EOF
else
    cat > "$UNINSTALL_DOC" <<EOF
# How to disconnect Claude Code from Clawvisor (alias-only install)

1. Remove the \`claude-cv()\` function from your shell rc. The exact text
   that was appended is recorded under
   ~/.clawvisor/diffs/$AGENT_NAME/claude_cv.json — match-and-remove it
   from the file listed there.
2. Delete the token file: rm ~/.clawvisor/agents/$AGENT_NAME.json
3. Revoke the agent in the Clawvisor dashboard under Agents → $AGENT_NAME → Delete.
4. Open a new shell to drop the claude-cv function.
EOF
fi
echo "✓ Wrote revert recipe to $UNINSTALL_DOC"

echo
if [ "$INSTALL_MODE_LABEL" = default-everywhere ]; then
    echo "Done. Restart Claude Code so the new env keys take effect."
else
    echo "Done. Open a new shell or 'source $RC' to pick up claude-cv."
fi
